@model WebApplication.Models.BienImmobilier

@{
    ViewData["Title"] = "Supprimer un bien - Ymmo";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white py-3">
                    <h3 class="card-title mb-0 text-center">
                        <i class="bi bi-exclamation-triangle"></i> Confirmation de suppression
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h4 class="text-secondary">Êtes-vous sûr de vouloir supprimer ce bien ?</h4>
                        <p class="text-muted">Cette action est irréversible et retirera le bien du catalogue.</p>
                    </div>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Titre :</div>
                            <div class="col-sm-8">@Model.Titre</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Ville :</div>
                            <div class="col-sm-8">@Model.Ville</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Prix :</div>
                            <div class="col-sm-8 text-danger fw-bold">@Model.Prix.ToString("N0") €</div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 fw-bold">Référence :</div>
                            <div class="col-sm-8 text-muted">ID #@Model.Id</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-center gap-3">
                        <input type="hidden" asp-for="Id" />

                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle"></i> Annuler
                        </a>

                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Confirmer la suppression
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>