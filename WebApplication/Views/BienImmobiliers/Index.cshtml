@model IEnumerable<WebApplication.Models.BienImmobilier>

@{
    ViewData["Title"] = "Nos Biens Immobiliers";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-5 bg-light">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Recherche libre</label>
                    <input type="text" name="searchString" class="form-control" placeholder="Ex: Jardin, calme..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Ville</label>
                    <input type="text" name="ville" class="form-control" placeholder="Ex: Aix-en-Provence" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold">Type</label>
                    <select name="typeBien" class="form-select">
                        <option value="">Tous les types</option>
                        <option value="Appartement">Appartement</option>
                        <option value="Maison">Maison</option>
                        <option value="Terrain">Terrain</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Prix max</label>
                    <div class="input-group">
                        <input type="number" name="prixMax" class="form-control" placeholder="Budget" />
                        <span class="input-group-text">€</span>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Bien immobilier">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-primary">@item.Type</span>
                            <h5 class="text-primary fw-bold mb-0">@item.Prix.ToString("N0") €</h5>
                        </div>
                        <h5 class="card-title fw-bold text-truncate">@item.Titre</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-geo-alt"></i> @item.Ville</p>
                        <p class="card-text text-truncate">@item.Description</p>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold"><i class="bi bi-arrows-fullscreen"></i> @item.Surface m²</span>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm">Découvrir</a>
                        </div>
                    </div>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="card-footer bg-white border-top-0 pb-3 d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm flex-grow-1"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light btn-sm text-danger flex-grow-1"><i class="bi bi-trash"></i></a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>