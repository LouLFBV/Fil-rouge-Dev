@model IEnumerable<WebApplication.Models.BienImmobilier>

@{
    ViewData["Title"] = "Gestion du Parc Immobilier";
    // Force l'utilisation du Layout pour retrouver le menu bleu
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary"><i class="bi bi-building"></i> Catalogue des Biens</h1>
        <a asp-controller="BienImmobiliers" asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Ajouter un nouveau bien
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Titre)</th>
                        <th>@Html.DisplayNameFor(model => model.Ville)</th>
                        <th>@Html.DisplayNameFor(model => model.Prix)</th>
                        <th>Surface</th>
                        <th>Type</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@Html.DisplayFor(modelItem => item.Titre)</td>
                            <td><i class="bi bi-geo-alt text-danger"></i> @Html.DisplayFor(modelItem => item.Ville)</td>
                            <td class="text-success fw-bold">@item.Prix.ToString("N0") €</td>
                            <td>@item.Surface m²</td>
                            <td><span class="badge bg-info text-dark">@item.Type</span></td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Détails">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning mt-4 text-center">
            Aucun bien n'est répertorié pour le moment. Cliquez sur "Ajouter" pour commencer.
        </div>
    }
</div>