@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email confirmé";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>

                    <h1 class="display-6 fw-bold text-dark">Bienvenue chez Ymmo Pro !</h1>
                    <p class="lead text-muted mb-4">Votre adresse email a été validée avec succès.</p>

                    @if (!string.IsNullOrEmpty(Model.StatusMessage))
                    {
                        <div class="alert alert-success border-0 small mb-4">
                            @Model.StatusMessage
                        </div>
                    }

                    <div class="d-grid gap-2 col-8 mx-auto">
                        <a asp-page="./Login" class="btn btn-primary btn-lg shadow-sm">
                            <i class="bi bi-box-arrow-in-right"></i> Se connecter maintenant
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 border-0">
                    <p class="mb-0 small text-muted">Vous pouvez désormais accéder au catalogue et gérer vos biens immobiliers.</p>
                </div>
            </div>
        </div>
    </div>
</div>